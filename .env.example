# NVIDIA API
NVIDIA_API_KEY=your_nvidia_api_key_here

# Ngrok (optional - for exposing local server)
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
NGROK_ENABLED=true

# Server
HOST=0.0.0.0
PORT=8000

# GPU
GPU_ENABLED=true

# Processing
MAX_WORKERS=4
WHISPER_MODEL_SIZE=large-v3-turbo

# Matching thresholds
CONFIDENCE_ACCEPT=0.85
CONFIDENCE_FALLBACK=0.50
CONFIDENCE_MIN=0.30
TOP_K_CANDIDATES=5
SCENE_REUSE_CONFIDENCE=0.90
